# MySQL 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=wicmail
DATABASE_URL=mysql+asyncmy://user:password@127.0.0.1:3306/wicmail

# JWT 配置
JWT_SECRET_KEY=change-me-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Cloudflare Email Worker 密钥
CLOUDFLARE_EMAIL_SECRET_KEY=change-me

# 默认管理员（首次启动时自动创建）
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change-me-strong-password

# 阿里云企业邮箱 SMTP 配置
SMTP_HOST=smtp.qiye.aliyun.com
SMTP_PORT=465
SMTP_USER=your-email@your-domain.com
SMTP_PASSWORD=your_password
SMTP_FROM_NAME=WIC Mail
SMTP_USE_SSL=true
