# 数据库（与 backend-mail 共用）
DATABASE_URL=mysql+asyncmy://user:password@127.0.0.1:3306/wicmail

# JWT（与 backend-mail 共用同一个密钥）
JWT_SECRET_KEY=change-me-use-same-key-as-backend-mail
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# 应用
APP_NAME=WicMail User Service
APP_ENV=production

# 邮箱域名
MAILBOX_DOMAIN=wic.edu.kg

# CORS 允许的源（逗号分隔，生产环境限制为实际域名）
CORS_ORIGINS=https://wicmail.opxqo.cn,http://localhost:3200

# Cloudflare R2 附件下载配置
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=wicmail-attachments
R2_PRESIGN_EXPIRE_SECONDS=3600
